<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body { font-family: Segoe UI, Arial, sans-serif; margin: 0; background: #f8fbf8; color: #0f172a; }
    main { width: min(960px, calc(100% - 32px)); margin: 48px auto; padding: 32px; background: white; border: 1px solid rgba(15,23,42,0.12); }
    .box { border: 1px solid rgba(15,23,42,0.12); padding: 16px; margin-top: 16px; }
    input, textarea { width: 100%; padding: 10px 12px; margin-top: 8px; margin-bottom: 12px; border: 1px solid rgba(15,23,42,0.2); font: inherit; }
    textarea { min-height: 120px; }
    button { padding: 10px 14px; border: 1px solid rgba(34,197,94,0.35); background: rgba(34,197,94,0.16); }
  </style>
</head>
<body><main>{{ content }}</main></body>
</html>
