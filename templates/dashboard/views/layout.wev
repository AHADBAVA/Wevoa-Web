<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <p class="eyebrow">Starter Pack</p>
        <h1>{{ title }}</h1>
      </div>
      <nav class="sidebar-nav">
        <a href="/">Overview</a>
      </nav>
      <div class="sidebar-copy">
        <p>Protected dashboard starter using WevoaWeb sessions, SQLite, auth helpers, and server-rendered task management.</p>
      </div>
    </aside>
    <main class="page-frame">{{ content }}</main>
  </div>
</body>
</html>
