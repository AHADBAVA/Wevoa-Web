import "shared.wev"

route "/" {
return view("home.wev", {
  title: "Home",
  site: site,
  env: config.env
})
}

route "/about" {
return view("about.wev", {
  title: "About",
  site: site
})
}

route "/users" {
let user_rows = db.query("SELECT name FROM users ORDER BY id ASC LIMIT 3")
let user_one = "No user yet"
let user_two = "Waiting for another user"
let user_three = "Waiting for another user"

if (len(user_rows) > 0) {
  user_one = user_rows[0].name
}

if (len(user_rows) > 1) {
  user_two = user_rows[1].name
}

if (len(user_rows) > 2) {
  user_three = user_rows[2].name
}

return view("users.wev", {
  title: "Users",
  site: site,
  user_one: user_one,
  user_two: user_two,
  user_three: user_three
})
}

route "/contact" {
return view("contact.wev", {
  title: "Contact",
  site: site
})
}

route "/submissions" {
let submission_rows = db.query("SELECT name, email, message FROM contact_submissions ORDER BY id DESC LIMIT 3")
let total = db.scalar("SELECT COUNT(*) FROM contact_submissions")

let latest = {
  name: "No submission yet",
  email: "",
  message: "Submit the contact form to see data appear here."
}

let previous = {
  name: "Waiting for more submissions",
  email: "",
  message: "The second-most-recent message will appear here."
}

let older = {
  name: "Waiting for more submissions",
  email: "",
  message: "A third recent message will appear here."
}

if (len(submission_rows) > 0) {
  latest = submission_rows[0]
}

if (len(submission_rows) > 1) {
  previous = submission_rows[1]
}

if (len(submission_rows) > 2) {
  older = submission_rows[2]
}

return view("submissions.wev", {
  title: "Submissions",
  site: site,
  total: total,
  latest: latest,
  previous: previous,
  older: older
})
}

route "/submit" method POST {
let name = request.form("name")
let email = request.form("email")
let message = request.form("message")

if (!name || name == "") {
  name = "Guest"
}

if (!email || email == "") {
  email = "not provided"
}

if (!message || message == "") {
  message = "No message was submitted."
}

db.exec("INSERT INTO contact_submissions (name, email, message) VALUES (?, ?, ?)", [name, email, message])

return view("submitted.wev", {
  title: "Submitted",
  site: site,
  name: name,
  email: email,
  message: message
})
}
