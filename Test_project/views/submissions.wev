extend "layout.wev"

section content {
<section class="page-card">
  <h1>Submitted Data</h1>
  <p class="lead">This page is rendered from SQLite data read by the backend.</p>
  <p class="body-copy">Total submissions in the database: {{ total }}</p>

  <div class="submission-list">
    <article class="submission-box">
      <p><strong>Latest</strong></p>
      <p><strong>Name:</strong> {{ latest.name }}</p>
      <p><strong>Email:</strong> {{ latest.email }}</p>
      <p>{{ latest.message }}</p>
    </article>

    <article class="submission-box">
      <p><strong>Previous</strong></p>
      <p><strong>Name:</strong> {{ previous.name }}</p>
      <p><strong>Email:</strong> {{ previous.email }}</p>
      <p>{{ previous.message }}</p>
    </article>

    <article class="submission-box">
      <p><strong>Older</strong></p>
      <p><strong>Name:</strong> {{ older.name }}</p>
      <p><strong>Email:</strong> {{ older.email }}</p>
      <p>{{ older.message }}</p>
    </article>
  </div>
</section>
}
