extend "layout.wev"

section content {
<section class="page-card">
  <h1>Contact Us</h1>
  <p class="lead">Submit this form to test POST handling and SQLite-backed persistence.</p>
  <p class="body-copy">The form writes to the project's main SQL database and the submissions page reads the latest rows back.</p>

  <form class="contact-form" method="POST" action="/submit">
    <input type="text" name="name" placeholder="Your Name">
    <input type="email" name="email" placeholder="Your Email">
    <textarea name="message" placeholder="Your Message"></textarea>
    <button type="submit">Send</button>
  </form>
</section>
}
